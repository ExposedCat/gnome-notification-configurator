#: dist/prefs.js:37
msgid "Global"
msgstr "Глобальні"

#: dist/prefs.js:43
msgid "Patterns"
msgstr "Патерни"

#: dist/prefs.js:72 dist/prefs.js:162
msgid "Enabled"
msgstr "Увімкнено"

#: dist/prefs.js:73
msgid "Master switch for all notification configuration"
msgstr "Головний перемикач для всіх налаштувань повідомлень"

#: dist/prefs.js:86
msgid "Notification Patterns"
msgstr "Патерни повідомлень"

#: dist/prefs.js:87
msgid "Per-pattern overrides that apply to matching notifications"
msgstr "Налаштування для кожного патерну, що застосовуються до відповідних повідомлень"

#: dist/prefs.js:99
msgid "New Pattern"
msgstr "Новий патерн"

#: dist/prefs.js:121
msgid "Unnamed Pattern"
msgstr "Безіменний патерн"

#: dist/prefs.js:143
msgid "No matchers configured"
msgstr "Збіги не налаштовано"

#: dist/prefs.js:149
msgid "Pattern Identity"
msgstr "Ідентифікація патерну"

#: dist/prefs.js:153
msgid "Short Name"
msgstr "Коротка назва"

#: dist/prefs.js:163
msgid "Enable this pattern override"
msgstr "Увімкнути це перевизначення патерну"

#: dist/prefs.js:172
msgid "Matchers"
msgstr "Збіги"

#: dist/prefs.js:173
msgid "RegExp patterns to match notifications"
msgstr "Регулярні вирази для збігу з повідомленнями"

#: dist/prefs.js:176 dist/prefs.js:656
msgid "App Name"
msgstr "Назва Застосунку"

#: dist/prefs.js:181 dist/prefs.js:661
msgid "Title"
msgstr "Заголовок"

#: dist/prefs.js:186 dist/prefs.js:666
msgid "Body"
msgstr "Вміст"

#: dist/prefs.js:192
msgid "Filtering"
msgstr "Фільтрація"

#: dist/prefs.js:193
msgid "Block or hide matching notifications"
msgstr "Блокування або приховування відповідних повідомлень"

#: dist/prefs.js:197
msgid "Filter Action"
msgstr "Дія фільтра"

#: dist/prefs.js:198
msgid "What to do with matching notifications"
msgstr "Що робити з відповідними повідомленнями"

#: dist/prefs.js:201 dist/prefs.js:278
msgid "Hide notification"
msgstr "Сховати повідомлення"

#: dist/prefs.js:202 dist/prefs.js:277
msgid "Close notification"
msgstr "Закрити повідомлення"

#: dist/prefs.js:212
msgid "Enable Filtering"
msgstr "Увімкнути Фільтрацію Повідомлень"

#: dist/prefs.js:213
msgid "Apply filter action to matching notifications"
msgstr "Застосувати дію фільтра до відповідних повідомлень"

#: dist/prefs.js:228
msgid "Delete Pattern"
msgstr "Видалити патерн"

#: dist/prefs.js:243
msgid "Pattern"
msgstr "Патерн"

#: dist/prefs.js:253
msgid "Rate Limiting"
msgstr "Обмеження Частоти"

#: dist/prefs.js:254
msgid "Control notification frequency per application"
msgstr "Налаштування частоти появи повідомлень окремих додатків"

#: dist/prefs.js:258
msgid "Notification Threshold"
msgstr "Поріг Зображення Повідомлень"

#: dist/prefs.js:259
msgid "Time in milliseconds before allowing duplicate notifications"
msgstr "Час у мілісекундах до зображення наступного повідомлення від додатку"

#: dist/prefs.js:273
msgid "Action"
msgstr "Дія"

#: dist/prefs.js:274
msgid "What to do with rate-limited notifications"
msgstr "Що робити з обмеженими за частотою повідомленнями"

#: dist/prefs.js:287
msgid "Enable Rate Limiting"
msgstr "Увімкнути Обмеження Частоти"

#: dist/prefs.js:288
msgid "Prevent duplicate notifications within threshold time"
msgstr "Заборонити повідомлення від додатку протягом певного часу"

#: dist/prefs.js:310
msgid "Notification Timeout"
msgstr "Тайм-аут"

#: dist/prefs.js:311
msgid "Control how long notifications stay visible"
msgstr "Налаштування часу зображення повідомлень"

#: dist/prefs.js:315
msgid "Timeout Duration"
msgstr "Тривалість тайм-ауту"

#: dist/prefs.js:316
msgid "Time in milliseconds before auto-dismiss (0 = never dismiss)"
msgstr ""
"Час у мілісекундах до автоматичного приховування повідомлень (0 = ніколи не "
"приховувати)"

#: dist/prefs.js:330
msgid "Ignore Idle State"
msgstr "Ігнорувати Неактивність"

#: dist/prefs.js:331
msgid "Keep showing notifications even when user is idle"
msgstr "Показувати повідомлення навіть коли користувач неактивний"

#: dist/prefs.js:339
msgid "Enable Timeout Override"
msgstr "Увімкнути перевизначення тайм-ауту"

#: dist/prefs.js:340
msgid "Override default notification timeout"
msgstr "Перевизначити стандартний тайм-аут повідомлень"

#: dist/prefs.js:362
msgid "Urgency"
msgstr "Терміновість"

#: dist/prefs.js:366
msgid "Force Normal Urgency"
msgstr "Примусова Звичайна Терміновість"

#: dist/prefs.js:367
msgid "Make all notifications use normal urgency level"
msgstr "Примусово встановити звичайну терміновість для всіх повідомлень"

#: dist/prefs.js:383
msgid "Display"
msgstr "Відображення"

#: dist/prefs.js:388
msgid "Enable Notifications in Fullscreen"
msgstr "Увімкнути повідомлення в повноекранному режимі"

#: dist/prefs.js:389
msgid "Show notifications even when applications are in fullscreen"
msgstr ""
"Зображати повідомлення навіть якщо додаток відкрито в повноекранному режимі"

#: dist/prefs.js:399
msgid "Horizontal Alignment"
msgstr "Горизонтальне вирівнювання"

#: dist/prefs.js:400
msgid "Horizontal position of notifications on screen"
msgstr "Горизонтальна позиція повідомлень на екрані"

#: dist/prefs.js:403 dist/prefs.js:420
msgid "Fill"
msgstr "Заповнити"

#: dist/prefs.js:404
msgid "Left"
msgstr "Зліва"

#: dist/prefs.js:405 dist/prefs.js:422
msgid "Center"
msgstr "Центр"

#: dist/prefs.js:406
msgid "Right"
msgstr "Справа"

#: dist/prefs.js:416
msgid "Vertical Alignment"
msgstr "Вертикальне вирівнювання"

#: dist/prefs.js:417
msgid "Vertical position of notifications on screen"
msgstr "Вертикальна позиція повідомлень на екрані"

#: dist/prefs.js:421
msgid "Top"
msgstr "Вгорі"

#: dist/prefs.js:423
msgid "Bottom"
msgstr "Внизу"

#: dist/prefs.js:444
msgid "Appearance"
msgstr "Зовнішній вигляд"

#: dist/prefs.js:445
msgid "Customize notification colors, font sizes, and margins"
msgstr "Налаштування кольорів, розмірів шрифтів та відступів повідомлень"

#: dist/prefs.js:449
msgid "Enable Custom Colors"
msgstr "Увімкнути власні кольори"

#: dist/prefs.js:450
msgid "Apply custom colors to notifications"
msgstr "Застосувати власні кольори до повідомлень"

#: dist/prefs.js:475
msgid "Margin Top"
msgstr "Відступ зверху"

#: dist/prefs.js:489
msgid "Margin Bottom"
msgstr "Відступ знизу"

#: dist/prefs.js:503
msgid "Margin Left"
msgstr "Відступ зліва"

#: dist/prefs.js:517
msgid "Margin Right"
msgstr "Відступ справа"

#: dist/prefs.js:531
msgid "Enable Custom Margins"
msgstr "Увімкнути власні відступи"

#: dist/prefs.js:532
msgid "Apply custom margins to notifications"
msgstr "Застосувати власні відступи до повідомлень"

#: dist/prefs.js:564
msgid "Override"
msgstr "Перевизначення"

#: dist/prefs.js:565
msgid "Override global setting for this pattern"
msgstr "Перевизначити глобальне налаштування для цього патерну"

#: dist/prefs.js:617
msgid "px"
msgstr "px"

#: dist/prefs.js:652
msgid "Test Notifications"
msgstr "Тестові Повідомлення"

#: dist/prefs.js:658
msgid "Test Application Name"
msgstr "Тестова Назва Застосунку"

#: dist/prefs.js:663
msgid "Test Notification Title"
msgstr "Тестовий Заголовок Повідомлення"

#: dist/prefs.js:668
msgid "Test Notification Body"
msgstr "Тестовий Вміст Повідомлення"

#: dist/prefs.js:673
msgid "Send Test Notification"
msgstr "Відправити Тестове Повідомлення"

#: dist/prefs.js:678
msgid "Test App"
msgstr "Тестовий Застосунок"

#: dist/prefs.js:679
msgid "Test Notification"
msgstr "Тестове Повідомлення"

#: dist/prefs.js:680
msgid "This is a test notification"
msgstr "Це тестове повідомлення"

