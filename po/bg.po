#: dist/prefs.js:58
msgid "Global"
msgstr "Глобални"

#: dist/prefs.js:64
msgid "Patterns"
msgstr "Патърни"

#: dist/prefs.js:93 dist/prefs.js:183
msgid "Enabled"
msgstr "Включено"

#: dist/prefs.js:94
msgid "Master switch for all notification configuration"
msgstr "Главен превключвател за цялата конфигурация на известията"

#: dist/prefs.js:107
msgid "Notification Patterns"
msgstr "Патърни за известия"

#: dist/prefs.js:108
msgid "Per-pattern overrides that apply to matching notifications"
msgstr "Настройки за патърн, приложими към съвпадащи известия"

#: dist/prefs.js:120
msgid "New Pattern"
msgstr "Нов патърн"

#: dist/prefs.js:142
msgid "Unnamed Pattern"
msgstr "Неименуван патърн"

#: dist/prefs.js:164
msgid "No matchers configured"
msgstr "Няма конфигурирани съвпадения"

#: dist/prefs.js:170
msgid "Pattern Identity"
msgstr "Идентификация на патърн"

#: dist/prefs.js:174
msgid "Short Name"
msgstr "Кратко име"

#: dist/prefs.js:184
msgid "Enable this pattern override"
msgstr "Включване на тази настройка за патърн"

#: dist/prefs.js:193
msgid "Matchers"
msgstr "Съвпадения"

#: dist/prefs.js:194
msgid "RegExp patterns to match notifications"
msgstr "Регулярни изрази за съвпадение с известия"

#: dist/prefs.js:197 dist/prefs.js:698
msgid "App Name"
msgstr "Име на приложението"

#: dist/prefs.js:202 dist/prefs.js:703
msgid "Title"
msgstr "Заглавие"

#: dist/prefs.js:207 dist/prefs.js:708
msgid "Body"
msgstr "Съдържание"

#: dist/prefs.js:213
msgid "Filtering"
msgstr "Филтриране"

#: dist/prefs.js:214
msgid "Block or hide matching notifications"
msgstr "Блокиране или скриване на съвпадащи известия"

#: dist/prefs.js:218
msgid "Filter Action"
msgstr "Действие при филтриране"

#: dist/prefs.js:219
msgid "What to do with matching notifications"
msgstr "Какво да се прави със съвпадащите известия"

#: dist/prefs.js:222 dist/prefs.js:299
msgid "Hide notification"
msgstr "Скриване на известието"

#: dist/prefs.js:223 dist/prefs.js:298
msgid "Close notification"
msgstr "Затваряне на известието"

#: dist/prefs.js:233
msgid "Enable Filtering"
msgstr "Включване на филтрирането"

#: dist/prefs.js:234
msgid "Apply filter action to matching notifications"
msgstr "Прилагане на действие за филтриране на съвпадащи известия"

#: dist/prefs.js:249
msgid "Delete Pattern"
msgstr "Изтриване на патърн"

#: dist/prefs.js:264
msgid "Pattern"
msgstr "Патърн"

#: dist/prefs.js:274
msgid "Rate Limiting"
msgstr "Ограничаване на честотата"

#: dist/prefs.js:275
msgid "Control notification frequency per application"
msgstr "Настройки за честотата на известията от едно и също приложение"

#: dist/prefs.js:279
msgid "Notification Threshold"
msgstr "Продължителност на блокирането"

#: dist/prefs.js:280
msgid "Time in milliseconds before allowing duplicate notifications"
msgstr ""
"Брой милисекунди, през които едно и също известие няма да се показва повторно"

#: dist/prefs.js:294
msgid "Action"
msgstr "Действие"

#: dist/prefs.js:295
msgid "What to do with rate-limited notifications"
msgstr "Какво да се прави с известията при ограничение на честотата"

#: dist/prefs.js:308
msgid "Enable Rate Limiting"
msgstr "Включване на ограничението"

#: dist/prefs.js:309
msgid "Prevent duplicate notifications within threshold time"
msgstr "Еднаквите известия ще бъдат блокирани за определеното време"

#: dist/prefs.js:331
msgid "Notification Timeout"
msgstr "Продължителност на видимостта на известията"

#: dist/prefs.js:332
msgid "Control how long notifications stay visible"
msgstr "Настройки за това колко дълго да остават видими известията"

#: dist/prefs.js:336
msgid "Timeout Duration"
msgstr "Продължителност на тайм-аута"

#: dist/prefs.js:337
msgid "Time in milliseconds before auto-dismiss (0 = never dismiss)"
msgstr ""
"Брой милисекунди, преди известието да бъде скрито (0 = без автоматично "
"скриване)"

#: dist/prefs.js:351
msgid "Ignore Idle State"
msgstr "Пренебрегване на състоянието на бездействие"

#: dist/prefs.js:352
msgid "Keep showing notifications even when user is idle"
msgstr "Показване на известия, дори когато потребителят не прави нищо"

#: dist/prefs.js:360
msgid "Enable Timeout Override"
msgstr "Включване на промяна на тайм-аута"

#: dist/prefs.js:361
msgid "Override default notification timeout"
msgstr "Промяна на стандартния тайм-аут на известията"

#: dist/prefs.js:383
msgid "Urgency"
msgstr "Спешност"

#: dist/prefs.js:387
msgid "Force Normal Urgency"
msgstr "Принудителен нормален приоритет"

#: dist/prefs.js:388
msgid "Make all notifications use normal urgency level"
msgstr "Всички известия ще се третират като обикновени"

#: dist/prefs.js:404
msgid "Display"
msgstr "Дисплей"

#: dist/prefs.js:409
msgid "Enable Notifications in Fullscreen"
msgstr "Включване на известия в пълноекранен режим"

#: dist/prefs.js:410
msgid "Show notifications even when applications are in fullscreen"
msgstr ""
"Показване на известия, дори когато има приложение работещо на цял екран"

#: dist/prefs.js:420
msgid "Horizontal Alignment"
msgstr "Хоризонтално подравняване"

#: dist/prefs.js:421
msgid "Horizontal position of notifications on screen"
msgstr "Хоризонтална позиция на известията на екрана"

#: dist/prefs.js:424 dist/prefs.js:441
msgid "Fill"
msgstr "Запълване"

#: dist/prefs.js:425
msgid "Left"
msgstr "Вляво"

#: dist/prefs.js:426 dist/prefs.js:443
msgid "Center"
msgstr "В средата"

#: dist/prefs.js:427
msgid "Right"
msgstr "Вдясно"

#: dist/prefs.js:437
msgid "Vertical Alignment"
msgstr "Вертикално подравняване"

#: dist/prefs.js:438
msgid "Vertical position of notifications on screen"
msgstr "Вертикална позиция на известията на екрана"

#: dist/prefs.js:442
msgid "Top"
msgstr "Горе"

#: dist/prefs.js:444
msgid "Bottom"
msgstr "Долу"

#: dist/prefs.js:465
msgid "Appearance"
msgstr "Външен вид"

#: dist/prefs.js:466
msgid "Customize notification styles and margins"
msgstr "Персонализиране на стиловете и полетата на известията"

#: dist/prefs.js:470
msgid "Hide App Title Row"
msgstr "Скриване на реда със заглавието на приложението"

#: dist/prefs.js:471
msgid "Hide title and time row"
msgstr "Скриване на реда със заглавието и часа"

#: dist/prefs.js:478
msgid "Enable Custom Styles"
msgstr "Включване на персонализирани стилове"

#: dist/prefs.js:479
msgid "Apply custom styles to notifications"
msgstr "Прилагане на персонализирани стилове на известията"

#: dist/prefs.js:484
msgid "Margin Top"
msgstr "Поле отгоре"

#: dist/prefs.js:498
msgid "Margin Bottom"
msgstr "Поле отдолу"

#: dist/prefs.js:512
msgid "Margin Left"
msgstr "Поле отляво"

#: dist/prefs.js:526
msgid "Margin Right"
msgstr "Поле отдясно"

#: dist/prefs.js:540
msgid "Enable Custom Margins"
msgstr "Включване на персонализирани полета"

#: dist/prefs.js:541
msgid "Apply custom margins to notifications"
msgstr "Прилагане на персонализирани полета на известията"

#: dist/prefs.js:604
msgid "Override"
msgstr "Промяна"

#: dist/prefs.js:605
msgid "Override global setting for this pattern"
msgstr "Промяна на глобалната настройка за този патърн"

#: dist/prefs.js:659
msgid "px"
msgstr "px"

#: dist/prefs.js:694
msgid "Test Notifications"
msgstr "Пробно известие"

#: dist/prefs.js:700
msgid "Test Application Name"
msgstr "Пробно име на приложение"

#: dist/prefs.js:705
msgid "Test Notification Title"
msgstr "Пробно заглавие на известие"

#: dist/prefs.js:710
msgid "Test Notification Body"
msgstr "Пробен текст на известие"

#: dist/prefs.js:715
msgid "Send Test Notification"
msgstr "Показване на пробно известие"

#: dist/prefs.js:720
msgid "Test App"
msgstr "Пробно приложение"

#: dist/prefs.js:721
msgid "Test Notification"
msgstr "Пробно известие"

#: dist/prefs.js:722
msgid "This is a test notification"
msgstr "Това е пробно известие"

