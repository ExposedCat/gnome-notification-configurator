#: dist/prefs.js:93 dist/prefs.js:183
msgid "Enabled"
msgstr "Ingeschakeld"

#: dist/prefs.js:94
msgid "Master switch for all notification configuration"
msgstr "Hoofdschakelaar voor alle meldingsconfiguratie"

#: dist/prefs.js:107
msgid "Notification Patterns"
msgstr "Meldingspatronen"

#: dist/prefs.js:108
msgid "Per-pattern overrides that apply to matching notifications"
msgstr ""
"Aanpassingen per patroon die van toepassing zijn op overeenkomende meldingen"

#: dist/prefs.js:120
msgid "New Pattern"
msgstr "Nieuw patroon"

#: dist/prefs.js:142
msgid "Unnamed Pattern"
msgstr "Naamloos patroon"

#: dist/prefs.js:164
msgid "No matchers configured"
msgstr "Geen overeenkomsten ingesteld"

#: dist/prefs.js:170
msgid "Pattern Identity"
msgstr "Patroonidentiteit"

#: dist/prefs.js:174
msgid "Short Name"
msgstr "Korte naam"

#: dist/prefs.js:184
msgid "Enable this pattern override"
msgstr "Patroonaanpassing inschakelen"

#: dist/prefs.js:193
msgid "Matchers"
msgstr "Overeenkomsten"

#: dist/prefs.js:194
msgid "RegExp patterns to match notifications"
msgstr "Reguliere uitdrukkingen om meldingen te filteren"

#: dist/prefs.js:197 dist/prefs.js:762
msgid "App Name"
msgstr "Toepassingsnaam"

#: dist/prefs.js:202 dist/prefs.js:767
msgid "Title"
msgstr "Titel"

#: dist/prefs.js:207 dist/prefs.js:772
msgid "Body"
msgstr "Inhoud"

#: dist/prefs.js:213
msgid "Filtering"
msgstr "Filteren"

#: dist/prefs.js:214
msgid "Block or hide matching notifications"
msgstr "Blokkeer of verberg overeenkomende meldingen"

#: dist/prefs.js:218
msgid "Filter Action"
msgstr "Filteractie"

#: dist/prefs.js:219
msgid "What to do with matching notifications"
msgstr "Wat er met overeenkomende meldingen moet gebeuren"

#: dist/prefs.js:222 dist/prefs.js:341
msgid "Hide notification"
msgstr "Melding verbergen"

#: dist/prefs.js:223 dist/prefs.js:340
msgid "Close notification"
msgstr "Melding sluiten"

#: dist/prefs.js:233
msgid "Enable Filtering"
msgstr "Filteren inschakelen"

#: dist/prefs.js:234
msgid "Apply filter action to matching notifications"
msgstr "Filteractie toepassen op overeenkomende meldingen"

#: dist/prefs.js:249
msgid "Delete Pattern"
msgstr "Patroon verwijderen"

#: dist/prefs.js:264
msgid "Pattern"
msgstr "Patroon"

#: dist/prefs.js:274
msgid "Notification Center"
msgstr "Meldingencentrum"

#: dist/prefs.js:275
msgid "Control how matching notifications stack together"
msgstr "Bepaal hoe overeenkomende meldingen worden gegroepeerd"

#: dist/prefs.js:279
msgid "Disable Stacking"
msgstr "Stapelen uitschakelen"

#: dist/prefs.js:280
msgid "Create a separate entry for each matching notification"
msgstr "Maak een afzonderlijk item voor elke overeenkomende melding"

#: dist/prefs.js:289
msgid "Maximum Per Source"
msgstr "Maximum per bron"

#: dist/prefs.js:290
msgid "Number of notifications kept for one application"
msgstr "Aantal meldingen dat per toepassing wordt bewaard"

#: dist/prefs.js:316
msgid "Rate Limiting"
msgstr "Hoeveelheid beperken"

#: dist/prefs.js:317
msgid "Control notification frequency per application"
msgstr "Geef aan hoeveel meldingen een toepassing mag tonen"

#: dist/prefs.js:321
msgid "Notification Threshold"
msgstr "Tijd tussen meldingen"

#: dist/prefs.js:322
msgid "Time in milliseconds before allowing duplicate notifications"
msgstr ""
"De tijd (in milliseconden) voordat dubbele meldingen getoond mogen worden"

#: dist/prefs.js:336
msgid "Action"
msgstr "Actie"

#: dist/prefs.js:337
msgid "What to do with rate-limited notifications"
msgstr "Wat er met beperkte meldingen moet gebeuren"

#: dist/prefs.js:350
msgid "Enable Rate Limiting"
msgstr "Hoeveelheidsbeperking inschakelen"

#: dist/prefs.js:351
msgid "Prevent duplicate notifications within threshold time"
msgstr "Voorkom dubbele meldingen binnen de ingestelde tijdspanne"

#: dist/prefs.js:373
msgid "Notification Timeout"
msgstr "Meldingen verbergen na"

#: dist/prefs.js:374
msgid "Control how long notifications stay visible"
msgstr "Geef aan hoelang meldingen getoond dienen te worden"

#: dist/prefs.js:378
msgid "Timeout Duration"
msgstr "Time-outduur"

#: dist/prefs.js:379
msgid "Time in milliseconds before auto-dismiss (0 = never dismiss)"
msgstr ""
"De tijd (in milliseconden) voordat meldingen worden verborgen (0 = nooit)"

#: dist/prefs.js:393
msgid "Ignore Idle State"
msgstr "Inactiviteit negeren"

#: dist/prefs.js:394
msgid "Keep showing notifications even when user is idle"
msgstr "Blijf meldingen tonen, zelfs als de gebruiker in kwestie inactief is"

#: dist/prefs.js:402
msgid "Enable Timeout Override"
msgstr "Time-outaanpassing inschakelen"

#: dist/prefs.js:403
msgid "Override default notification timeout"
msgstr "Standaard meldingstime-out aanpassen"

#: dist/prefs.js:425
msgid "Urgency"
msgstr "Urgentie"

#: dist/prefs.js:429
msgid "Force Normal Urgency"
msgstr "Normaal urgentieniveau gebruiken"

#: dist/prefs.js:430
msgid "Make all notifications use normal urgency level"
msgstr "Toon alle meldingen zonder verhoogde of verlaagde urgentie"

#: dist/prefs.js:446
msgid "Window Attention"
msgstr "Vensteraandacht"

#: dist/prefs.js:447
msgid "Control what happens when a window demands attention"
msgstr "Bepaal wat er gebeurt als een venster aandacht vraagt"

#: dist/prefs.js:451
msgid "Activate Window Instead of Notifying"
msgstr "Venster activeren in plaats van melden"

#: dist/prefs.js:452
msgid "Switch directly to the window instead of showing a notification"
msgstr ""
"Schakel direct over naar het venster in plaats van een melding te tonen"

#: dist/prefs.js:468
msgid "Display"
msgstr "Weergave"

#: dist/prefs.js:473
msgid "Enable Notifications in Fullscreen"
msgstr "Meldingen in schermvullende weergave inschakelen"

#: dist/prefs.js:474
msgid "Show notifications even when applications are in fullscreen"
msgstr ""
"Toon meldingen, zelfs als toepassingen de schermvullende weergave gebruiken"

#: dist/prefs.js:484
msgid "Horizontal Alignment"
msgstr "Horizontale uitlijning"

#: dist/prefs.js:485
msgid "Horizontal position of notifications on screen"
msgstr "Horizontale positie van meldingen op het scherm"

#: dist/prefs.js:488 dist/prefs.js:505
msgid "Fill"
msgstr "Vullen"

#: dist/prefs.js:489
msgid "Left"
msgstr "Links"

#: dist/prefs.js:490 dist/prefs.js:507
msgid "Center"
msgstr "Midden"

#: dist/prefs.js:491
msgid "Right"
msgstr "Rechts"

#: dist/prefs.js:501
msgid "Vertical Alignment"
msgstr "Verticale uitlijning"

#: dist/prefs.js:502
msgid "Vertical position of notifications on screen"
msgstr "Verticale positie van meldingen op het scherm"

#: dist/prefs.js:506
msgid "Top"
msgstr "Bovenaan"

#: dist/prefs.js:508
msgid "Bottom"
msgstr "Onderaan"

#: dist/prefs.js:529
msgid "Appearance"
msgstr "Vormgeving"

#: dist/prefs.js:530
msgid "Customize notification styles and margins"
msgstr "Pas meldingsstijlen en marges aan"

#: dist/prefs.js:534
msgid "Hide App Title Row"
msgstr "App-titelrij verbergen"

#: dist/prefs.js:535
msgid "Hide title and time row"
msgstr "Titel- en tijdsrij verbergen"

#: dist/prefs.js:542
msgid "Enable Custom Styles"
msgstr "Aangepaste stijlen inschakelen"

#: dist/prefs.js:543
msgid "Apply custom styles to notifications"
msgstr "Aangepaste stijlen toepassen op meldingen"

#: dist/prefs.js:548
msgid "Margin Top"
msgstr "Marge boven"

#: dist/prefs.js:562
msgid "Margin Bottom"
msgstr "Marge onder"

#: dist/prefs.js:576
msgid "Margin Left"
msgstr "Marge links"

#: dist/prefs.js:590
msgid "Margin Right"
msgstr "Marge rechts"

#: dist/prefs.js:604
msgid "Enable Custom Margins"
msgstr "Eigen marges inschakelen"

#: dist/prefs.js:605
msgid "Apply custom margins to notifications"
msgstr "Eigen marges toepassen op meldingen"

#: dist/prefs.js:668
msgid "Override"
msgstr "Aanpassing"

#: dist/prefs.js:669
msgid "Override global setting for this pattern"
msgstr "Globale instelling aanpassen voor dit patroon"

#: dist/prefs.js:723
msgid "px"
msgstr "px"

#: dist/prefs.js:758
msgid "Test Notifications"
msgstr "Meldingen uitproberen"

#: dist/prefs.js:764
msgid "Test Application Name"
msgstr "Toepassingsnaam uitproberen"

#: dist/prefs.js:769
msgid "Test Notification Title"
msgstr "Meldingstitel voorvertonen"

#: dist/prefs.js:774
msgid "Test Notification Body"
msgstr "Meldingsinhoud voorvertonen"

#: dist/prefs.js:779
msgid "Send Test Notification"
msgstr "Testmelding versturen"

#: dist/prefs.js:784
msgid "Test App"
msgstr "Toepassingstest"

#: dist/prefs.js:785
msgid "Test Notification"
msgstr "Testmelding"

#: dist/prefs.js:786
msgid "This is a test notification"
msgstr "Dit is een testmelding"

